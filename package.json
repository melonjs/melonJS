{
	"name": "melonjs-monorepo",
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo build && eslint && biome check && turbo test:types",
		"test": "turbo build && vitest --config packages/melonjs/vitest.config.ts",
		"doc": "pnpm -F melonjs doc",
		"publish-melonjs": "gh workflow run publish.yml -f package=melonjs",
		"publish-melonjs:dry": "gh workflow run publish.yml -f package=melonjs -f dry-run=true",
		"publish-debug-plugin": "gh workflow run publish.yml -f package=debug-plugin",
		"publish-debug-plugin:dry": "gh workflow run publish.yml -f package=debug-plugin -f dry-run=true",
		"publish-tiled-inflate-plugin": "gh workflow run publish.yml -f package=tiled-inflate-plugin",
		"publish-tiled-inflate-plugin:dry": "gh workflow run publish.yml -f package=tiled-inflate-plugin -f dry-run=true",
		"publish-spine-plugin": "gh workflow run publish.yml -f package=spine-plugin",
		"publish-spine-plugin:dry": "gh workflow run publish.yml -f package=spine-plugin -f dry-run=true"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"@biomejs/biome": "2.4.9",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.2",
		"@vitest/browser": "^4.1.2",
		"@vitest/browser-playwright": "^4.1.2",
		"eslint": "^10.2.0",
		"eslint-plugin-jsdoc": "^62.9.0",
		"globals": "^17.4.0",
		"lefthook": "^2.1.5",
		"tsconfig": "workspace:^",
		"tsx": "^4.21.0",
		"turbo": "^2.9.5",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"devDependencies": {
		"eslint-plugin-react-refresh": "^0.5.2",
		"playwright": "^1.59.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"core-js",
			"esbuild",
			"lefthook",
			"playwright"
		],
		"overrides": {
			"minimatch@<4.0.0": "3.1.4",
			"minimatch@>=9.0.0 <9.0.7": "9.0.7",
			"ajv@<6.14.0": "6.14.0",
			"vite": "8.0.3",
			"esbuild": "0.27.4"
		}
	}
}
