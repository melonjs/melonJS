{
	"extends": "tsconfig/base.json",
	"compilerOptions": {
		"rootDir": "src",
		"declarationDir": "build",
		"removeComments": false,
		"declarationMap": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": false
	},
	"include": ["src"]
}
